APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Performance Metrics
# If false, /api/perf-metrics will log to laravel.log but will not write to DB.
PERF_METRICS_PERSIST=false

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=file
# CACHE_PREFIX=

# Performance (recommended for production / multi-node): Redis
# SESSION_DRIVER=redis
# CACHE_STORE=redis
# QUEUE_CONNECTION=redis

# Redis connection
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

#----------------------------------------
# Database Seeder Credentials
# All passwords should be changed in production!
#----------------------------------------
SEEDER_ADMIN_NAME="System Administrator"
SEEDER_ADMIN_EMAIL=admin@hris.local
SEEDER_ADMIN_PASSWORD=admin123
SEEDER_ADMIN_POSITION="ICT Manager"
SEEDER_ADMIN_DIVISION="Chief of Hospital Offices Division"
SEEDER_ADMIN_SECTION="Information and Communications Technology Unit"

SEEDER_HR_MANAGER_NAME="HR Manager"
SEEDER_HR_MANAGER_EMAIL=hr@hris.local
SEEDER_HR_MANAGER_PASSWORD=hr123
SEEDER_HR_MANAGER_POSITION="Human Resource Management Officer III"
SEEDER_HR_MANAGER_DIVISION="Finance and Administrative Division"
SEEDER_HR_MANAGER_SECTION="Human Resource Management Section"

SEEDER_HR_STAFF_NAME="HR Staff"
SEEDER_HR_STAFF_EMAIL=hrstaff@hris.local
SEEDER_HR_STAFF_PASSWORD=hr123
SEEDER_HR_STAFF_POSITION="HR Specialist"
SEEDER_HR_STAFF_DIVISION="Finance and Administrative Division"
SEEDER_HR_STAFF_SECTION="Human Resource Management Section"

SEEDER_EMPLOYEE_NAME="Juan Dela Cruz"
SEEDER_EMPLOYEE_EMAIL=employee@hris.local
SEEDER_EMPLOYEE_PASSWORD=employee123
SEEDER_EMPLOYEE_POSITION="Medical Officer III"
SEEDER_EMPLOYEE_DIVISION="Treatment and Rehabilitation Division"
SEEDER_EMPLOYEE_SUBDIVISION="Non-Residential Treatment & Rehabilitation"
SEEDER_EMPLOYEE_SECTION="Medical Section"

# Demo users password (used for admin01, hr01, hr02, employee01, employee02)
SEEDER_DEMO_PASSWORD=password

#----------------------------------------
# Authentication Configuration
#----------------------------------------
AUTH_LEGACY_DOMAIN="@hris.local"

#----------------------------------------
# Theme Configuration
#----------------------------------------
THEME_PRIMARY="#013CFC"
THEME_PRIMARY_DARK="#0031BC"
THEME_PRIMARY_LIGHT="#60C8FC"
THEME_SUCCESS="#10b981"
THEME_WARNING="#f59e0b"
THEME_DANGER="#ef4444"
THEME_INFO="#3b82f6"
THEME_DARK_MODE=true
THEME_DARK_MODE_DEFAULT=false
THEME_LOGO=
THEME_FAVICON=

#----------------------------------------
# Default Values Configuration
#----------------------------------------
DEFAULT_USER_FIRST_NAME="User"
DEFAULT_USER_LAST_NAME=""
DEFAULT_USER_NAME="User"
DEFAULT_USER_INITIAL="U"
DEFAULT_MEMBER_SINCE="January 2024"
DEFAULT_AVATAR_INITIAL="U"
DEFAULT_AVATAR_PATH=avatars
DEFAULT_BACKUP_PATH=backups
DEFAULT_BACKUP_DISK=local
DEFAULT_PAGINATION=20

#----------------------------------------
# Session Demo Mode
#----------------------------------------
SESSION_DEMO_MODE=false
SESSION_DEMO_SESSION_ID="mock-session-2"
